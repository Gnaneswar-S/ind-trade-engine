.pytype/
cython_debug/
.pypirc
pip-log.txt
pip-delete-this-directory.txt
*.sage.py

# Notebook checkpoints
.ipynb_checkpoints
profile_default/
ipython_config.py

# PDM / Poetry / Pipenv lock files (optional — include if team project)
.pdm-python
.pdm-build/


# ══════════════════════════════════════════════════════════════════════
# 📄 GENERATED OUTPUT FILES (don't commit AI-generated reports)
# ══════════════════════════════════════════════════════════════════════

*.pdf
*.docx
reports/
exports/


# ══════════════════════════════════════════════════════════════════════
# 🧪 LOCAL TEST / DEV FILES (not needed in production)
# ══════════════════════════════════════════════════════════════════════

gemini_test.py
*_test.py
test_*.py
scratch*.py
debug*.py


